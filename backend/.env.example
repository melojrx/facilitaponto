# =============================================================================
# PONTO DIGITAL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.
# =============================================================================

# Django
SECRET_KEY=gere-uma-chave-segura-com-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de Dados (opção 1 - recomendada para PROD)
# Exemplo: postgresql://postgres:postgres@db:5432/ponto_digital
# Se DATABASE_URL estiver definida, ela tem prioridade sobre as variáveis DB_* abaixo.
DATABASE_URL=

# Banco de Dados (opção 2 - compatibilidade DEV local)
DB_NAME=ponto_digital
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Onboarding - provider público de consulta CNPJ
CNPJA_OPEN_BASE_URL=https://open.cnpja.com
CNPJA_OPEN_TIMEOUT=4.0

# MinIO (S3 compatível)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ponto-digital
MINIO_ENDPOINT=http://minio:9000

# Biometria — Chave Fernet para criptografar embeddings faciais (LGPD)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BIOMETRIA_KEY=gere-uma-chave-fernet-aqui
DEEPFACE_HOME=/opt/deepface
PRELOAD_BIOMETRIC_MODELS=1

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.development
